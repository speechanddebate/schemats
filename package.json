{
  "name": "schemats",
  "type": "module",
  "version": "0.1.3",
  "description": "Schemats Frontend Client for Tabroom.com",
  "private": true,
  "author": "Chris Palmer <palmer@tabroom.com> (https://speechanddebate.org)",
  "license": "RPL 1.5",
  "keywords": [
    "speech",
    "schemats",
    "debate",
    "congress",
    "tabulation",
    "forensics",
    "tabroom",
    "speechanddebate",
    "NSDA"
  ],
  "engines": {
    "node": ">= 24.0.0"
  },
  "bugs": {
    "url": "https://github.com/speechanddebate/tabroom/issues"
  },
  "scripts": {
    "production": "vite build --mode production && node -r dotenv/config build/index.js",
    "staging": "vite build --mode staging",
    "build": "vite build --mode production",
    "dev": "vite dev",
    "preview": "vite preview",
    "orval": "orval --config ./config/orval.config.ts",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@flowbite-svelte-plugins/datatable": "^0.4.1",
    "@storybook/addon-a11y": "^10.2.13",
    "@storybook/addon-docs": "^10.2.13",
    "@storybook/addon-svelte-csf": "^5.0.11",
    "@storybook/addon-vitest": "^10.2.13",
    "@storybook/sveltekit": "^10.2.13",
    "@sveltejs/adapter-node": "^5.5.3",
    "@sveltejs/kit": "^2.47.0",
    "@sveltejs/vite-plugin-svelte": "^6.1.4",
    "@tanstack/svelte-query-devtools": "^6.0.0",
    "@testing-library/svelte": "^5.3.1",
    "@tsconfig/svelte": "^5.0.4",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.0.0",
    "@typescript-eslint/parser": "^8.22.0",
    "@vitest/browser-playwright": "^4.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "@vitest/eslint-plugin": "^1.1.25",
    "eslint": "^9.17.0",
    "eslint-import-resolver-typescript": "^4.4.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-storybook": "^10.2.13",
    "eslint-plugin-svelte": "^3.12.1",
    "flowbite-svelte": "1.29.1",
    "flowbite-svelte-icons": "^3.1.0",
    "globals": "^17.0.0",
    "husky": "^9.0.11",
    "jsdom": "^28.1.0",
    "msw": "^2.12.10",
    "msw-storybook-addon": "^2.0.6",
    "orval": "^8.4.1",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "storybook": "^10.2.13",
    "svelte": "^5.38.6",
    "svelte-check": "^4.3.1",
    "svelte-eslint-parser": "^1.4.0",
    "svelte-preprocess": "^6.0.3",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.1.4",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@faker-js/faker": "^10.0.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/postcss": "^4.1.12",
    "@tailwindcss/typography": "^0.5.15",
    "@tanstack/query-async-storage-persister": "^5.90.7",
    "@tanstack/svelte-query": "^6.0.3",
    "@tanstack/svelte-query-persist-client": "^6.0.5",
    "ag-grid-community": "^34.3.1",
    "luxon": "^3.7.2",
    "tailwindcss": "^4.1.11"
  },
  "msw": {
    "workerDirectory": [
      "static"
    ]
  }
}

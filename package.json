{
  "name": "schemats",
  "type": "module",
  "version": "0.2.0",
  "description": "Schemats Frontend Client for Tabroom.com",
  "private": true,
  "author": "Chris Palmer <palmer@tabroom.com> (https://speechanddebate.org)",
  "license": "RPL 1.5",
  "packageManager": "^npm@11.8.0",
  "keywords": [
    "speech",
    "schemats",
    "debate",
    "congress",
    "tabulation",
    "forensics",
    "tabroom",
    "speechanddebate",
    "NSDA"
  ],
  "bugs": {
    "url": "https://github.com/speechanddebate/tabroom/issues"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "msw": {
    "workerDirectory": [
      "static"
    ]
  },
  "scripts": {
    "production": "vite build --mode production && node -r dotenv/config build/index.js",
    "staging": "vite build --mode staging",
    "build": "vite build --mode production",
    "build-storybook": "storybook build",
    "dev": "vite dev",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:ci": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --output=machine",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest --project unit && npm run test:e2e",
    "test:unit": "svelte-kit sync && vitest --project unit",
	"test:ci": "npm run test:ci:unit && npm run test:ci:a11y && npm run test:ci:e2e",
    "test:ci:unit": "svelte-kit sync && vitest --project unit --watch=false --run",
	"test:ci:e2e": "playwright test -c ./config/testing --reporter=github",
    "test:ci:a11y": "svelte-kit sync && vitest --project storybook --run",
    "test:storybook": "svelte-kit sync && vitest --project storybook --run",
    "test:storybook:mobile": "svelte-kit sync && STORYBOOK_VIEWPORT=mobile vitest --project storybook --run",
    "test:storybook:desktop": "svelte-kit sync && STORYBOOK_VIEWPORT=desktop vitest --project storybook --run",
    "test:storybook:multi": "npm run test:storybook:mobile && npm run test:storybook:desktop",
    "test:e2e": "playwright test -c ./config/testing",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "playwright install && husky",
    "orval": "orval --config ./config/orval.config.ts",
    "storybook": "storybook dev -p 6006"
  },
	"dependencies": {
		"@svar-ui/svelte-filter": "^2.5.0",
		"@svar-ui/svelte-grid": "^2.6.0",
		"@tailwindcss/container-queries": "^0.1.1",
		"@tailwindcss/forms": "^0.5.9",
		"@tailwindcss/postcss": "^4.1.12",
		"@tailwindcss/typography": "^0.5.15",
		"@tanstack/query-async-storage-persister": "^5.90.7",
		"@tanstack/svelte-query": "^6.0.3",
		"@tanstack/svelte-query-persist-client": "^6.0.5",
		"@tanstack/svelte-table": "^9.0.0-alpha.32",
		"luxon": "^3.7.2",
		"tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@eslint/compat": "^2.0.3",
    "@eslint/json": "^1.2.0",
    "@faker-js/faker": "^10.3.0",
    "@msw/playwright": "^0.6.7",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.3.0",
    "@storybook/addon-docs": "^10.3.0",
    "@storybook/addon-svelte-csf": "^5.0.11",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/sveltekit": "^10.3.0",
    "@stylistic/eslint-plugin-js": "^4.4.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.50.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@sveltejs/vite-plugin-svelte-inspector": "^5.0.2",
    "@tanstack/svelte-query-devtools": "^6.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@tsconfig/svelte": "^5.0.4",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.22.0",
    "@vitest/browser": "^4.1.0",
    "@vitest/browser-playwright": "^4.1.1",
    "@vitest/coverage-v8": "^4.1.1",
    "@vitest/eslint-plugin": "^1.1.25",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-storybook": "^10.3.0",
    "eslint-plugin-svelte": "^3.12.1",
    "flowbite-svelte": "^1.33.1",
    "flowbite-svelte-icons": "^3.1.0",
    "globals": "^17.0.0",
    "husky": "^9.0.11",
    "jsdom": "^29.0.1",
    "msw": "^2.13.3",
    "msw-storybook-addon": "^2.0.6",
    "orval": "^8.5.1",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "storybook": "^10.3.0",
    "sv": "^0.15.1",
    "svelte": "^5.46.4",
    "svelte-animated-icons": "^1.0.0",
    "svelte-check": "^4.3.6",
    "svelte-eslint-parser": "^1.6.0",
    "svelte-preprocess": "^6.0.3",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.1.4",
    "vitest": "^4.1.1"
  }
}
